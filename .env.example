# =============================================================================
# DailyCTI Configuration — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
# Generate a strong password: openssl rand -base64 32
DATABASE_URL=postgresql+asyncpg://dailycti:CHANGE_ME@localhost:5432/dailycti
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Anthropic (Claude API) ---
# Required for article summarization and ATT&CK mapping
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- NVD API (optional but recommended) ---
# Raises rate limit from 5 to 50 requests per 30 seconds
# Request at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# --- AlienVault OTX (optional) ---
# Free API key for threat intelligence feeds
# Register at: https://otx.alienvault.com/
OTX_API_KEY=

# --- SMTP (email delivery) ---
# Simple SMTP for newsletter delivery (~20 subscribers)
# Works with Gmail, Outlook, Fastmail, or any SMTP server
# Gmail: smtp.gmail.com:587 (use App Password, not your login password)
# Outlook: smtp.office365.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER_EMAIL=your-email@gmail.com

# --- Slack Integration (optional) ---
# Webhook URL for pushing alerts to Slack channels
SLACK_WEBHOOK_URL=

# --- MISP Integration (optional) ---
# MISP instance for pushing extracted IOCs
MISP_URL=
MISP_API_KEY=

# --- Application Settings ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Newsletter schedule (cron expression, UTC)
NEWSLETTER_CRON=0 5 * * *

# Maximum articles to summarize with Claude per run (cost control)
MAX_CLAUDE_SUMMARIES=100

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
API_JWT_SECRET=change-this-to-a-random-secret

# --- VirusTotal (optional) ---
# Paid API recommended for serious use (free: 4 req/min)
VIRUSTOTAL_API_KEY=

# --- GitHub (optional) ---
# For GitHub Advisory Database GraphQL queries
GITHUB_TOKEN=
